{
  "name": "ollama-copilot",
  "displayName": "Ollama for GitHub Copilot",
  "version": "0.1.0",
  "description": "Run Ollama models with full tool and vision support in GitHub Copilot Chat. Manage local and remote Ollama instances directly from VS Code.",
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "ollama",
    "ai",
    "copilot",
    "chat",
    "llama",
    "local",
    "models",
    "coding",
    "code assistant",
    "tools",
    "vision"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/ollama-copilot.git"
  },
  "license": "MIT",
  "qna": "marketplace",
  "author": {
    "name": "Daniel Sieradski",
    "email": "daniel@self.agency",
    "url": "https://self.agency"
  },
  "publisher": "selfagency",
  "main": "./dist/extension.js",
  "scripts": {
    "check-types": "tsc --noEmit",
    "compile": "pnpm run check-types && pnpm run lint && tsup",
    "deploy": "vsce publish --no-dependencies",
    "format": "oxfmt 'src/**/*.ts' --write",
    "lint:fix": "oxlint 'src/**/*.ts' --fix",
    "lint": "oxlint 'src/**/*.ts'",
    "package": "pnpm run check-types && pnpm run lint && NODE_ENV=production tsup",
    "prepare": "husky",
    "release": "zx ./scripts/release.mjs",
    "release:pre": "zx ./scripts/release.mjs --pre-release",
    "test": "vitest run src",
    "test:extension": "vscode-test test/integration",
    "test:coverage": "vitest run --coverage",
    "vscode:prepublish": "pnpm run package",
    "watch:build": "tsup --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "watch": "run-p watch:*"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  },
  "contributes": {
    "commands": [
      {
        "command": "ollama-copilot.manageAuthToken",
        "title": "Ollama: Manage Auth Token"
      }
    ],
    "configuration": {
      "title": "Ollama",
      "properties": {
        "ollama.host": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL (local or remote)"
        },
        "ollama.contextLength": {
          "type": "number",
          "default": 0,
          "description": "Override context window size (0 = use model default)"
        },
        "ollama.refreshInterval": {
          "type": "number",
          "default": 5,
          "description": "Sidebar auto-refresh interval in seconds (0 = off)"
        }
      }
    },
    "languageModelChatProviders": [
      {
        "vendor": "ollama",
        "displayName": "Ollama",
        "configuration": {
          "managementCommand": "ollama-copilot.manageAuthToken"
        }
      }
    ],
    "chatParticipants": [
      {
        "id": "ollama-copilot.ollama",
        "name": "ollama",
        "fullName": "Ollama",
        "description": "Chat with an Ollama model",
        "isSticky": true
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelChatProvider:ollama",
    "onChatParticipant:ollama-copilot.ollama"
  ],
  "dependencies": {
    "ollama": "^0.5.8"
  },
  "devDependencies": {
    "@octokit/rest": "^22.0.1",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/dts": "^0.4.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "assert": "^2.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "npm-run-all": "^4.1.5",
    "ora": "^9.3.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.15.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vscode": "^1.1.37",
    "zx": "^8.8.5"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "icon": "logo.png",
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
