{
  "name": "ollama-copilot",
  "displayName": "Ollama for GitHub Copilot",
  "version": "0.1.0",
  "description": "Run Ollama models with full tool and vision support in GitHub Copilot Chat. Manage local and remote Ollama instances directly from VS Code.",
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "chat",
    "code assistant",
    "coding",
    "copilot",
    "llama",
    "local",
    "models",
    "ollama",
    "tools",
    "vision"
  ],
  "license": "MIT",
  "author": {
    "name": "Daniel Sieradski",
    "email": "daniel@self.agency",
    "url": "https://self.agency"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/ollama-copilot.git"
  },
  "qna": "marketplace",
  "publisher": "selfagency",
  "main": "./dist/extension.js",
  "scripts": {
    "prepare": "husky"
  },
  "dependencies": {
    "ollama": "^0.6.3"
  },
  "devDependencies": {
    "@octokit/rest": "^22.0.1",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/dts": "^0.4.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "assert": "^2.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "npm-run-all": "^4.1.5",
    "ora": "^9.3.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vscode": "^1.1.37",
    "zx": "^8.8.5"
  },
  "lint-staged": {
    "scripts/*.mjs": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "src/**/*.ts": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "**/*.{json,yml,yaml,md}": [
      "oxfmt --write"
    ]
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ollama-explorer",
          "title": "Ollama",
          "icon": "$(package)"
        }
      ]
    },
    "views": {
      "ollama-explorer": [
        {
          "icon": "$(package)",
          "id": "ollama-sidebar",
          "name": "Models"
        }
      ]
    },
    "commands": [
      {
        "command": "ollama-copilot.manageAuthToken",
        "title": "Ollama: Manage Auth Token"
      },
      {
        "command": "ollama-copilot.refreshSidebar",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ollama-copilot.deleteModel",
        "title": "Delete Model",
        "icon": "$(trash)"
      },
      {
        "command": "ollama-copilot.pullModel",
        "title": "Pull Model",
        "icon": "$(cloud-download)"
      },
      {
        "command": "ollama-copilot.stopModel",
        "title": "Stop Model",
        "icon": "$(stop-circle)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ollama-copilot.refreshSidebar",
          "when": "view == ollama-sidebar",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ollama-copilot.deleteModel",
          "when": "view == ollama-sidebar && viewItem == model",
          "group": "inline"
        },
        {
          "command": "ollama-copilot.stopModel",
          "when": "view == ollama-sidebar && viewItem == running",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Ollama",
      "properties": {
        "ollama.host": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL (local or remote)"
        },
        "ollama.contextLength": {
          "type": "number",
          "default": 0,
          "description": "Override context window size (0 = use model default)"
        },
        "ollama.debounceInterval": {
          "type": "number",
          "default": 300,
          "description": "Debounce interval for sidebar refresh in milliseconds"
        },
        "ollama.localModelRefreshInterval": {
          "type": "number",
          "default": 30,
          "description": "Auto-refresh local and running models interval in seconds"
        },
        "ollama.libraryRefreshInterval": {
          "type": "number",
          "default": 21600,
          "description": "Auto-refresh library catalog interval in seconds (default 6 hours)"
        }
      }
    },
    "languageModelChatProviders": [
      {
        "vendor": "ollama",
        "displayName": "Ollama",
        "configuration": {
          "managementCommand": "ollama-copilot.manageAuthToken"
        }
      }
    ],
    "chatParticipants": [
      {
        "id": "ollama-copilot.ollama",
        "name": "ollama",
        "fullName": "Ollama",
        "description": "Chat with an Ollama model",
        "isSticky": true
      }
    ]
  },
  "activationEvents": [
    "onChatParticipant:ollama-copilot.ollama",
    "onLanguageModelChatProvider:ollama",
    "onStartupFinished"
  ],
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
